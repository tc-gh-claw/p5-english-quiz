  "grammar": {
    "tenses": [
      {
        "type": "multiple_choice",
        "question": "She _____ to school every day.",
        "options": ["go", "goes", "going", "went"],
        "answer": 1,
        "explanation": "Present Simple - 習慣性動作用第三人稱單數加 'es'"
      },
      {
        "type": "multiple_choice",
        "question": "Look! The children _____ in the playground.",
        "options": ["play", "are playing", "played", "have played"],
        "answer": 1,
        "explanation": "Present Continuous - 'Look!' 表示正在發生的動作"
      },
      {
        "type": "multiple_choice",
        "question": "I _____ my homework already.",
        "options": ["finish", "finished", "have finished", "am finishing"],
        "answer": 2,
        "explanation": "Present Perfect - 'already' 表示已完成的動作"
      },
      {
        "type": "multiple_choice",
        "question": "They _____ a movie last night.",
        "options": ["watch", "watched", "have watched", "watching"],
        "answer": 1,
        "explanation": "Past Simple - 'last night' 表示過去特定時間"
      },
      {
        "type": "multiple_choice",
        "question": "While I _____, the phone rang.",
        "options": ["cook", "was cooking", "cooked", "have cooked"],
        "answer": 1,
        "explanation": "Past Continuous - 表示過去某動作進行時被另一動作打斷"
      },
      {
        "type": "multiple_choice",
        "question": "We _____ visit grandma tomorrow.",
        "options": ["will", "are", "were", "have"],
        "answer": 0,
        "explanation": "Simple Future - 'will' 表示將來的動作"
      }
    ],
    "articles": [
      {
        "type": "multiple_choice",
        "question": "I ate _____ apple for breakfast.",
        "options": ["a", "an", "the", "-"],
        "answer": 1,
        "explanation": "'Apple' 以元音開頭，用 'an'"
      },
      {
        "type": "multiple_choice",
        "question": "_____ sun is very hot today.",
        "options": ["A", "An", "The", "-"],
        "answer": 2,
        "explanation": "世上獨一無二的事物前用 'the'"
      },
      {
        "type": "multiple_choice",
        "question": "She is _____ teacher.",
        "options": ["a", "an", "the", "-"],
        "answer": 0,
        "explanation": "泛指一位老師，用 'a'"
      }
    ],
    "relative_pronouns": [
      {
        "type": "multiple_choice",
        "question": "This is the boy _____ won the competition.",
        "options": ["who", "which", "where", "whose"],
        "answer": 0,
        "explanation": "指人用 'who'"
      },
      {
        "type": "multiple_choice",
        "question": "The book _____ I bought is interesting.",
        "options": ["who", "which", "where", "whose"],
        "answer": 1,
        "explanation": "指物用 'which' 或 'that'"
      },
      {
        "type": "multiple_choice",
        "question": "This is the restaurant _____ we had dinner.",
        "options": ["who", "which", "where", "whose"],
        "answer": 2,
        "explanation": "指地點用 'where'"
      }
    ]
